{
  "name": "@growsz/grandpa-ron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "build:cf": "prisma generate && next build && npx @cloudflare/next-on-pages",
    "deploy:cf": "npm run build:cf && wrangler pages deploy .vercel/output/static --project-name=grandpa-rons",
    "preview:cf": "wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "postinstall": "npx prisma generate || true",
    "db:seed": "pnpm exec tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "prisma": {
    "seed": "pnpm exec tsx prisma/seed.ts"
  },
  "dependencies": {
    "@growsz/arcorc-layout": "workspace:*",
    "@growsz/wcg-core": "workspace:*",
    "@growsz/core": "workspace:*",
    "@growsz/dbity-runtime": "workspace:*",
    "@growsz/orcbase-core": "workspace:*",
    "@growsz/dbity-core": "workspace:*",
    "@growsz/siwx-core": "workspace:*",
    "@growsz/siwx-session": "workspace:*",
    "pg": "^8.16.0",
    "@emailjs/browser": "^4.4.1",
    "@emailjs/nodejs": "^5.0.2",
    "@google/genai": "^1.30.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.24",
    "lucide-react": "catalog:",
    "mammoth": "^1.11.0",
    "motion": "^12.23.24",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-google-recaptcha": "^3.1.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.4.1",
    "stripe": "catalog:",
    "@stripe/stripe-js": "catalog:",
    "tailwind-merge": "^3.4.0",
    "zod": "catalog:",
    "@prisma/client": "^6.7.0",
    "prisma": "^6.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@cloudflare/next-on-pages": "^1.14.0",
    "wrangler": "^4.21.0",
    "@tailwindcss/postcss": "catalog:",
    "@types/minimatch": "^5.1.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-google-recaptcha": "^2.1.9",
    "tailwindcss": "catalog:",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.4.0",
