# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Google Places API (for Reviews Widget)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key
NEXT_PUBLIC_GOOGLE_PLACE_ID=your_google_place_id

# Business Contact Information
NEXT_PUBLIC_BUSINESS_PHONE=(220) 666-2520
NEXT_PUBLIC_BUSINESS_EMAIL=fgreatful@gmail.com

# EmailJS Configuration
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Google reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key

# Database (Prisma + Neon PostgreSQL)
# ============================================
# PRODUCTION - Neon Serverless PostgreSQL (RECOMMENDED)
# ============================================
# Sign up at: https://neon.tech
# Create a project and copy the connection string
#
# Pooled connection (for Vercel Edge/Serverless - recommended):
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connect_timeout=15"
#
# Direct connection (for Prisma Migrate - optional):
# DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"
#
# ============================================
# LOCAL DEVELOPMENT - SQLite
# ============================================
# For local dev, change provider in schema.prisma to "sqlite" and use:
# DATABASE_URL="file:./dev.db"
#
DATABASE_URL=your_neon_pooled_connection_string
DIRECT_URL=your_neon_direct_connection_string

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Dbity Engine (Backend Trinity)
# =============================================================================
# Controls backend engine routing. When set to 'production', Dbity PostgreSQL
# adapter takes over from Prisma. DATABASE_URL MUST be postgresql:// (not SQLite).
# DBITY_MODE=local        # Default: uses Prisma adapter
# DBITY_MODE=production   # Uses Dbity primary engine (PostgreSQL via pg driver)

# =============================================================================
# SIWX Identity (Auth)
# =============================================================================
# SIWX_JWT_SECRET=your_jwt_secret_for_production
# CRON_SECRET=your_cron_secret_for_emission_scheduler

# =============================================================================
# WorkGun Tier (Feature Gating)
# =============================================================================
WORKGUN_TIER=professional

# =============================================================================
# Gmail CRM Inbox (Optional — Professional tier)
# =============================================================================
# GMAIL_CLIENT_ID=your_google_oauth_client_id
# GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
# GMAIL_REDIRECT_URI=http://localhost:3000/api/crm/inbox/connect/callback
